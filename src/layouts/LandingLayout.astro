---
import '../styles/global.css';
import '../styles/animations.css';
import FacebookPixel from '../components/tracking/FacebookPixel.astro';
import GoogleTagManager from '../components/tracking/GoogleTagManager.astro';
import GoogleAnalytics from '../components/tracking/GoogleAnalytics.astro';
import HotmartPixel from '../components/tracking/HotmartPixel.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  siteName?: string;
  locale?: string;
  preloadImage?: string;
  fonts?: string[];
  colors?: {
    primary?: string;
    secondary?: string;
    accent?: string;
    background?: string;
  };
  tracking?: {
    facebookPixelId?: string;
    googleAnalyticsId?: string;
    gtmId?: string;
    hotmartPixelId?: string;
  };
}

const {
  title,
  description,
  ogImage,
  canonicalUrl,
  siteName = 'Hotmart Landings',
  locale = 'es_LA',
  preloadImage,
  fonts,
  colors,
  tracking,
} = Astro.props;

const isDark = colors?.background && colors.background !== '#ffffff' && colors.background !== '#f1faee';
const bodyBg = colors?.background || '#ffffff';
const bodyText = isDark ? '#f3f4f6' : '#111827';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="oUL19hE3-Ic4H3423rYkkBLXWmnVqpHq81t2h2qLDQw" />
    <meta name="theme-color" content={colors?.primary || '#833cf6'} />
    <title>{title}</title>

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content={siteName} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Preconnect to common domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Custom fonts -->
    {fonts && fonts.map((fontUrl) => (
      <link href={fontUrl} rel="stylesheet" />
    ))}

    <!-- Custom CSS variables per product -->
    {colors && (
      <style define:vars={{
        'color-product-primary': colors.primary || '#e63946',
        'color-product-secondary': colors.secondary || '#1d3557',
        'color-product-accent': colors.accent || '#f4a261',
        'color-product-bg': colors.background || '#f1faee',
      }}></style>
    )}

    <!-- Tracking Scripts -->
    {tracking?.gtmId && <GoogleTagManager gtmId={tracking.gtmId} />}
    {tracking?.googleAnalyticsId && <GoogleAnalytics gaId={tracking.googleAnalyticsId} />}
    {tracking?.facebookPixelId && <FacebookPixel pixelId={tracking.facebookPixelId} />}
    {tracking?.hotmartPixelId && <HotmartPixel pixelId={tracking.hotmartPixelId} />}
  </head>
  <body
    class="min-h-screen antialiased"
    style={`background-color: ${bodyBg}; color: ${bodyText};`}
  >
    <slot />

    <!-- UTM capture + inject into Hotmart links (including React-hydrated) -->
    <script>
      import { captureUtmParams } from '../utils/utm';
      captureUtmParams();

      function injectUtmsIntoHotmartLinks(root: ParentNode = document) {
        const utms = JSON.parse(sessionStorage.getItem('hotmart_utm_params') || '{}');
        if (Object.keys(utms).length === 0) return;

        root.querySelectorAll('a[href*="go.hotmart.com"]').forEach((link) => {
          const anchor = link as HTMLAnchorElement;
          const url = new URL(anchor.href);
          // Only inject if not already present
          if (!url.searchParams.has('utm_source')) {
            Object.entries(utms).forEach(([k, v]) => url.searchParams.set(k, v as string));
            anchor.href = url.toString();
          }
        });
      }

      // 1. Rewrite existing links immediately
      injectUtmsIntoHotmartLinks();

      // 2. Watch for React-hydrated components that add links after initial load
      const utmsExist = Object.keys(JSON.parse(sessionStorage.getItem('hotmart_utm_params') || '{}')).length > 0;
      if (utmsExist) {
        const observer = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            for (const node of mutation.addedNodes) {
              if (node instanceof HTMLElement) {
                // Check the added node itself and its descendants
                if (node.matches?.('a[href*="go.hotmart.com"]')) {
                  injectUtmsIntoHotmartLinks(node.parentNode || document);
                } else if (node.querySelector?.('a[href*="go.hotmart.com"]')) {
                  injectUtmsIntoHotmartLinks(node);
                }
              }
            }
          }
        });

        observer.observe(document.body, { childList: true, subtree: true });

        // Auto-disconnect after 30s (all React hydration should be done by then)
        setTimeout(() => observer.disconnect(), 30000);
      }
    </script>
  </body>
</html>
