---
interface Props {
  gaId: string;
}

const { gaId } = Astro.props;
---

<!-- Google Analytics 4 -->
<script is:inline define:vars={{ gaId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', gaId);
</script>
<script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${Astro.props.gaId}`} async></script>
