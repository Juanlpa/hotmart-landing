---
interface Props {
  benefits: string[];
  title?: string;
  columns?: 2 | 3;
  icon?: string;
}

const { benefits, title = '¿Qué vas a obtener?', columns = 2, icon = '✓' } = Astro.props;
---

<section class="py-16 md:py-24 px-4 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl md:text-4xl font-bold text-center mb-12">
      {title}
    </h2>

    <div class={`grid grid-cols-1 ${columns === 3 ? 'md:grid-cols-3' : 'md:grid-cols-2'} gap-6`}>
      {benefits.map((benefit, index) => (
        <div
          class="flex items-start gap-3 p-4 bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <span class="flex-shrink-0 w-8 h-8 bg-green-100 text-green-600 rounded-full flex items-center justify-center font-bold text-sm">
            {icon}
          </span>
          <p class="text-gray-700 text-base md:text-lg">{benefit}</p>
        </div>
      ))}
    </div>
  </div>
</section>
