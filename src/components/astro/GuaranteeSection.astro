---
interface Props {
  days: number;
  productName?: string;
}

const { days, productName = 'este producto' } = Astro.props;
---

<section class="py-16 md:py-20 px-4 bg-white">
  <div class="max-w-3xl mx-auto text-center">
    <div class="inline-block mb-6">
      <div class="w-24 h-24 md:w-32 md:h-32 mx-auto bg-green-100 rounded-full flex items-center justify-center">
        <svg class="w-12 h-12 md:w-16 md:h-16 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
    </div>

    <h2 class="text-2xl md:text-3xl font-bold mb-4">
      Garantía Incondicional de {days} Días
    </h2>
    <p class="text-gray-600 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto">
      Si por cualquier motivo {productName} no cumple con tus expectativas,
      tienes <strong>{days} días</strong> para solicitar un reembolso completo.
      Sin preguntas, sin complicaciones. Tu inversión está 100% protegida
      por la garantía de Hotmart.
    </p>
  </div>
</section>
