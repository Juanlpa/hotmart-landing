<!-- ViewContent tracking at midpoint -->
<div data-midpoint class="absolute" style="top: 50%; left: 0; width: 1px; height: 1px;"></div>
<script>
  import { fireTrackingEvent } from '../../config/tracking';

  let fired = false;
  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !fired) {
      fired = true;
      fireTrackingEvent({ event: 'ViewContent', productSlug: 'te-vas-a-transformar' });
    }
  }, { threshold: 0.5 });

  const midpoint = document.querySelector('[data-midpoint]');
  if (midpoint) observer.observe(midpoint);
</script>

