---
import LandingLayout from '../../layouts/LandingLayout.astro';
import CTAButton from '../../components/react/CTAButton';
import CountdownTimer from '../../components/react/CountdownTimer';
import SocialProof from '../../components/react/SocialProof';
import FAQAccordion from '../../components/react/FAQAccordion';
import ExitIntentModal from '../../components/react/ExitIntentModal';
import FloatingCTA from '../../components/react/FloatingCTA';
import { getProduct } from '../../config/products';
import { buildAffiliateLink } from '../../utils/hotmart';

const product = getProduct('te-vas-a-transformar')!;
const affiliateUrl = buildAffiliateLink(product.affiliateLink, product.slug);
const discount = Math.round(((product.originalPrice - product.currentPrice) / product.originalPrice) * 100);

const imgBase = '/images/te-vas-a-transformar/assets';

const painPointIcons: Record<string, string> = {
  ban: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>`,
  fatigue: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6l3-3"/><path d="M12 8L9 5"/><path d="M5.07 19A9 9 0 1 1 20.93 9"/><path d="M18 14a4 4 0 1 1-8 0 4 4 0 0 1 8 0z"/></svg>`,
  cycle: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10"/><path d="M20.49 15a9 9 0 01-14.85 3.36L1 14"/></svg>`,
  pause: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="10" y1="15" x2="10" y2="9"/><line x1="14" y1="15" x2="14" y2="9"/></svg>`,
};

const includedIcons: Record<string, string> = {
  food: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
  muscle: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5L2 12l4.5 5.5"/><path d="M17.5 6.5L22 12l-4.5 5.5"/><line x1="8" y1="12" x2="16" y2="12"/><circle cx="8" cy="12" r="2"/><circle cx="16" cy="12" r="2"/></svg>`,
  device: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  book: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>`,
  search: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  chat: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
  clipboard: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>`,
  trending: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  trophy: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 010-5H6"/><path d="M18 9h1.5a2.5 2.5 0 000-5H18"/><path d="M4 22h16"/><path d="M10 22V8a6 6 0 00-6-6h16a6 6 0 00-6 6v14"/><path d="M10 14h4"/></svg>`,
};

const beforeAfterTestimonials = [
  { name: 'Andreina Rodriguez', image: `${imgBase}/resultado-andreina.jpg`, result: 'Día 1 vs Día 28' },
  { name: 'Enly Krisbell', image: `${imgBase}/resultado-enly.jpg`, result: 'Transformación completa' },
  { name: 'Santiago Diaz', image: `${imgBase}/resultado-santiago.jpg`, result: 'Resultados en 30 días' },
];
---

<LandingLayout
  title={product.seo.title}
  description={product.seo.description}
  ogImage={product.seo.ogImage}
  colors={product.colors}
  tracking={product.tracking}
  fonts={['https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap']}
>

<style>
  body { font-family: 'Space Grotesk', sans-serif; }
</style>

<!-- ===== MOBILE HERO IMAGE (full-width, above hero) ===== -->
<div class="md:hidden relative w-full">
  <img
    src={`${imgBase}/logo-white.png`}
    alt="Te Vas a Transformar"
    class="absolute top-4 left-1/2 -translate-x-1/2 z-10 h-10 w-auto opacity-90"
    loading="eager"
  />
  <img
    src={`${imgBase}/coach-action.jpg`}
    alt="Coach del Método TVT"
    class="w-full aspect-[3/2] object-cover object-top"
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-[#0a0a0a]/40"></div>
</div>

<!-- ===== SECTION 1: HERO ===== -->
<header class="relative flex items-center pt-6 md:pt-16 pb-16 md:min-h-screen px-4 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-[#833cf6]/10 via-transparent to-transparent pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#833cf6]/8 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="container mx-auto max-w-6xl relative z-10">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <!-- Text side -->
      <div class="text-center md:text-left">
        <div class="inline-block px-4 py-1.5 bg-[#833cf6]/20 border border-[#833cf6]/30 text-[#833cf6] font-semibold rounded-full text-sm mb-8 animate-pulse">
          {discount}% DE DESCUENTO — OFERTA LIMITADA
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight tracking-tighter text-white uppercase mb-6" set:html={product.headline} />

        <p class="text-xl md:text-2xl text-gray-400 font-medium max-w-xl mb-10">
          {product.subheadline}
        </p>

        <div class="flex flex-col items-center md:items-start gap-4">
          <CTAButton
            client:visible
            href={affiliateUrl}
            text="¡QUIERO TRANSFORMARME AHORA!"
            subtext="Acceso inmediato · Pago 100% seguro"
            size="xl"
            variant="primary"
            pulse={true}
            glow={false}
            productSlug={product.slug}
            className="animate-glow-green !bg-[#22C55E] hover:!bg-[#16a34a] !rounded-2xl !shadow-[0_0_30px_rgba(34,197,94,0.3)]"
          />
        </div>

        <div class="flex flex-wrap justify-center md:justify-start gap-6 mt-8 text-sm text-gray-500">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Garantía de {product.guaranteeDays} días
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Pago seguro via Hotmart
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Acceso inmediato
          </span>
        </div>
      </div>

      <!-- Image side -->
      <div class="hidden md:block relative">
        <div class="absolute -inset-4 bg-gradient-to-br from-[#833cf6]/20 to-transparent rounded-3xl blur-2xl"></div>
        <img
          src={`${imgBase}/equipo.jpg`}
          alt="Equipo Te Vas a Transformar"
          class="relative rounded-2xl w-full object-cover shadow-2xl border border-white/5"
          loading="eager"
        />
      </div>
    </div>
  </div>
</header>

<!-- ===== SECTION 2: PAIN POINTS ===== -->
<section class="py-20 md:py-28 px-4 bg-zinc-950/50">
  <div class="container mx-auto max-w-3xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-4">
      ¿Cuántos años llevas <span class="text-[#833cf6]">"haciendo todo bien"</span> para bajar de peso...
    </h2>
    <p class="text-2xl md:text-3xl font-bold text-center text-white mb-12">
      ...pero sigues igual?
    </p>

    <div class="space-y-4">
      {product.painPoints?.map((point) => (
        <div class="flex items-start gap-4 p-5 rounded-xl glass-card">
          <span class="text-red-500 flex-shrink-0 mt-0.5" set:html={painPointIcons[point.icon || 'ban']} />
          <div>
            <p class="text-lg text-gray-200 font-medium">{point.title}</p>
            <p class="text-gray-400 text-sm mt-1">{point.description}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-xl md:text-2xl text-[#833cf6] font-bold text-center mt-12 italic">
      Es momento de dejar de luchar contra tu cuerpo y empezar a trabajar con él.
    </p>
  </div>
</section>

<!-- ===== SECTION 3: SOLUTION REVEAL ===== -->
<section class="py-20 md:py-28 px-4 text-center relative overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-[#833cf6]/15 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto max-w-4xl relative z-10">
    <p class="text-gray-500 uppercase tracking-widest text-sm mb-4">La solución existe</p>
    <h2 class="text-3xl md:text-5xl font-black text-white mb-6">
      Una vez dentro del programa, esto es lo que verás:
    </h2>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-10">
      No te vamos a decir que "te levantarás delgada y plana" haciendo lo mismo de siempre.
      Te vamos a dar las herramientas reales para transformarte.
    </p>

    <div class="relative max-w-3xl mx-auto group">
      <div class="absolute -inset-3 bg-gradient-to-r from-[#833cf6] to-purple-600 rounded-2xl blur opacity-20 group-hover:opacity-40 transition-opacity"></div>
      <div class="relative glass-card rounded-2xl p-8 md:p-12 flex flex-col items-center gap-6">
        <img
          src={`${imgBase}/logo-white.png`}
          alt="Logo Te Vas a Transformar"
          class="h-16 md:h-24 w-auto opacity-90"
          loading="lazy"
        />
        <p class="text-6xl md:text-8xl font-black text-white uppercase tracking-tighter mb-0">
          MÉTODO <span class="text-[#833cf6]">TVT</span>
        </p>
        <p class="text-gray-400">Te Vas a Transformar</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== SECTION 3.5: MEET YOUR COACH ===== -->
<section class="py-20 md:py-28 px-4 bg-zinc-950/50">
  <div class="container mx-auto max-w-6xl">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Image side -->
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-br from-[#833cf6]/20 to-transparent rounded-3xl blur-2xl"></div>
        <img
          src={`${imgBase}/coach-action.jpg`}
          alt="Coach del Método TVT entrenando"
          class="relative rounded-2xl w-full object-cover shadow-2xl border border-white/5"
          loading="lazy"
        />
      </div>
      <!-- Text side -->
      <div>
        <p class="text-[#833cf6] uppercase tracking-widest text-sm font-semibold mb-4">Tu guía en esta transformación</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Un equipo que <span class="text-[#833cf6]">practica lo que enseña</span>
        </h2>
        <p class="text-gray-400 text-lg leading-relaxed mb-6">
          Detrás del Método TVT hay entrenadores certificados que viven el fitness todos los días.
          No te van a dar consejos desde un escritorio — cada rutina, cada plan de comidas, cada ajuste
          viene de experiencia real con cientos de transformaciones exitosas.
        </p>
        <div class="grid grid-cols-2 gap-4">
          <div class="glass-card p-4 rounded-xl text-center">
            <p class="text-2xl font-black text-white">500+</p>
            <p class="text-gray-500 text-sm">Transformaciones</p>
          </div>
          <div class="glass-card p-4 rounded-xl text-center">
            <p class="text-2xl font-black text-white">30</p>
            <p class="text-gray-500 text-sm">Días de programa</p>
          </div>
          <div class="glass-card p-4 rounded-xl text-center">
            <p class="text-2xl font-black text-white">24/7</p>
            <p class="text-gray-500 text-sm">Soporte en comunidad</p>
          </div>
          <div class="glass-card p-4 rounded-xl text-center">
            <p class="text-2xl font-black text-white">5+</p>
            <p class="text-gray-500 text-sm">Años de experiencia</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Team photo -->
    <div class="mt-16 relative">
      <div class="absolute -inset-2 bg-gradient-to-r from-[#833cf6]/10 to-transparent rounded-2xl blur-xl"></div>
      <img
        src={`${imgBase}/equipo-completo.jpg`}
        alt="Equipo completo Te Vas a Transformar"
        class="relative rounded-2xl w-full object-cover shadow-xl border border-white/5 max-h-[400px] object-top"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 via-transparent to-transparent rounded-2xl"></div>
      <div class="absolute bottom-6 left-6 right-6 text-center">
        <p class="text-white font-bold text-lg">El equipo que te acompañará en cada paso</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== SECTION 4: WHAT'S INCLUDED ===== -->
<section class="py-20 md:py-28 bg-zinc-950/50 px-4">
  <div class="container mx-auto max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-4 uppercase tracking-tight">
      Todo lo que recibirás HOY:
    </h2>
    <p class="text-center text-gray-500 mb-16">11 herramientas para tu transformación completa</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {product.includedItems?.map((item, i) => (
        <div class:list={[
          'glass-card p-6 rounded-xl flex flex-col gap-3 transition-all hover:scale-[1.02]',
          i === (product.includedItems!.length - 1) && 'md:col-span-2 border-[#833cf6]/40',
        ]}>
          <span class="text-[#833cf6]" set:html={includedIcons[item.icon || 'check']} />
          <h3 class="text-lg font-bold text-white">{item.name}</h3>
          <p class="text-gray-400 text-sm flex-1">{item.description}</p>
          <span class:list={[
            'text-sm font-bold',
            item.value === 'INVALUABLE' ? 'text-[#833cf6] italic' : 'text-[#833cf6]',
          ]}>
            {item.value === 'INVALUABLE' ? 'INVALUABLE' : `Valorado en ${item.value}`}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== SECTION 5: PRICING ===== -->
<section class="py-20 md:py-28 px-4 relative overflow-hidden" id="pricing">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[#833cf6]/15 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto max-w-4xl text-center relative z-10">
    <h2 class="text-3xl md:text-5xl font-black text-white mb-8 uppercase">¿Cuánto es la inversión?</h2>

    <div class="glass-card border-2 border-[#833cf6]/30 p-8 md:p-12 rounded-3xl max-w-2xl mx-auto">
      <div class="inline-block px-5 py-2 bg-red-600 text-white font-bold rounded-full text-sm mb-6 animate-pulse">
        {discount}% DE DESCUENTO DISPONIBLE
      </div>

      <p class="text-gray-500 text-lg mb-2">Valor real estimado:</p>
      <p class="text-gray-500 text-3xl line-through mb-6">${product.originalPrice} {product.currency}</p>

      <div class="flex items-baseline justify-center gap-3 mb-8">
        <span class="text-2xl font-bold text-white">HOY POR SOLO</span>
        <span class="text-6xl md:text-8xl font-black text-[#22C55E] tracking-tighter">${product.currentPrice}</span>
        <span class="text-xl font-bold text-white">{product.currency}</span>
      </div>

      <a
        href={affiliateUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full py-6 bg-[#22C55E] hover:bg-[#16a34a] text-white text-xl md:text-2xl font-black rounded-2xl transition-all transform hover:scale-[1.02] shadow-[0_10px_40px_rgba(34,197,94,0.3)] mb-6 text-center animate-glow-green"
      >
        ¡ACCEDER AL MÉTODO TVT AHORA!
      </a>

      <div class="flex flex-wrap justify-center gap-6 text-gray-400 text-sm">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Acceso Inmediato
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Pago Único
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          Soporte incluido
        </span>
      </div>
    </div>
  </div>
</section>

<!-- ===== SECTION 6: COUNTDOWN ===== -->
{product.countdown?.enabled && (
  <section class="py-8 px-4">
    <CountdownTimer
      client:visible
      evergreen={product.countdown.evergreen}
      hours={product.countdown.hours}
      storageKey={`countdown_${product.slug}`}
      title="Esta oferta especial expira en:"
      className="text-white"
    />
  </section>
)}

<!-- ===== SECTION 7: TESTIMONIALS — BEFORE/AFTER REAL ===== -->
<section class="py-20 md:py-28 bg-zinc-950 px-4">
  <div class="container mx-auto max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-4 italic">
      Resultados <span class="underline decoration-[#833cf6] underline-offset-8">Reales</span>
    </h2>
    <p class="text-center text-gray-500 mb-12">Transformaciones verificadas de participantes del Método TVT</p>

    <!-- Before/After Gallery -->
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {beforeAfterTestimonials.map((t) => (
        <div class="glass-card rounded-2xl overflow-hidden group">
          <div class="relative overflow-hidden">
            <img
              src={t.image}
              alt={`Transformación de ${t.name}`}
              class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-4 text-center">
            <p class="text-white font-bold text-lg">{t.name}</p>
            <p class="text-[#833cf6] text-sm font-medium">{t.result}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Text testimonials -->
    <div class="grid md:grid-cols-3 gap-6">
      {product.testimonials.map((t) => (
        <div class="glass-card p-6 rounded-2xl flex flex-col gap-4">
          <div class="flex text-yellow-400 text-lg gap-0.5">
            {Array.from({ length: t.rating || 5 }).map(() => (
